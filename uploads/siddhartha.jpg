ta-testid="reviews-summary"><div class="summary-detail"><div class="summary-rating"><div class="star-rating-star-container summary-stars" data-testid="star-rating" style="height: 24px;"><div class="star-rating-full-star" style="padding-inline-end: 0px;"></div></div><span class="rating-value" data-testid="average-rating">5.0</span><div class="summary-rating-details"><i class="_icon_ed56b9e _black_7811826 i-expand summary-anchor-down" style="font-size: 24px;"></i></div></div><div class="summary-counts-row" data-testid="counts-row"><span class="summary-total-reviews" data-testid="total-reviews-desktop">3 Değerlendirme</span><div class="summary-total-comments"><span data-testid="total-comments-desktop">2 Yorum</span><img alt="fotoğraflı yorum iconu" class="summary-with-photos" height="14" src="./siddhartha_files/kamera-emoji6x.png" width="18" data-testid="image"></div></div></div></div><section class="slider" data-testid="slider" style="--slide-gap: 8px; --slide-edge-gap: 0px;"><div class="slider__viewport"><div class="slider__container" style="transform: translate3d(0px, 0px, 0px);"><div class="slider__slide" data-testid="slide"><div class="review-review" data-testid="review"><div class="review-content-header"><div class="review-header"><div class="star-rating-star-container review-stars" data-testid="star-rating" style="height: 13px;"><div class="star-rating-full-star" style="padding-inline-end: 0px;"></div></div><div class="review-details" data-testid="review-details"><span data-testid="user-full-name">S** E**</span><span class="review-elite" data-testid="elite">Elite Üye</span><span data-testid="comment-date">11 Nisan 2023</span></div></div><div class="review-extra-info-extra-info" data-testid="extra-info"></div><div class="comment-comment" data-testid="comment"><span width="0"><span><span>Çok beğendim teşekkür ederim!</span></span><span style="position: fixed; visibility: hidden; top: 0px; left: 0px;"><a href="https://www.trendyol.com/can-yayinlari/siddhartha-p-323